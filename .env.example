# Database
DATABASE_URL=postgres://zanajira:password@localhost:5432/zanajira?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-strong-secret-32-chars-min
JWT_REFRESH_SECRET=change-me-strong-refresh-secret-32

# ZanID Integration
ZANID_API_URL=https://zanid.go.tz/api
ZANID_API_KEY=your-zanid-api-key
ZANID_MOCK=true

# SMTP (Mailpit for dev: localhost:1025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zanajira.go.tz

# Application
UPLOAD_DIR=/var/zanajira/uploads
APP_URL=http://localhost:5173
PORT=8080
ENV=development
